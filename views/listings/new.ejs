<%- layout('layouts/boilerplate') %>
</body>
   
    <div class="row mt-3">
        <div class="col-8 offset-2">
    <h1 >Create a New Listing</h1>
    <form action="/listings" method="POST" class="needs-validation" novalidate enctype="multipart/form-data">
        <div class="mb-3">
        <label  for="title" class="form-label">Title:</label>
        <input type="text"  name="listing[title]" class="form-control" placeholder="Enter Title" required>
        
          <div class="invalid-feedback">Enter a valid title!</div>
          <div class="valid-feedback">Title looks good!</div>
        </div>
  <br>
       <div class="mb-3">
        <label for="description" class="form-label">Description:</label>
        <textarea  name="listing[description]" rows="4" cols="50" class="form-control" placeholder="Describe Your Property"required></textarea>

          <div class="invalid-feedback">Enter a valid description!</div>
   
        </div>
  
          <br>
           <div class="mb-3">
        <label for="image" class="form-label" >Upload Listing Image:</label>
        <input type="file"  name="listing[image]" class="form-control"  required>
        </div>
          <br>

         <div class="row"> 
       <div class="mb-3 col-4 md"> 
        <label for="price" class="form-label">Price (₹):</label>
        <input type="number"  name="listing[price]" class="form-control" placeholder="Enter Price" required>
         <div class="invalid-feedback">Enter a valid Price</div>
        </div>
          <br>
       <div class="mb-3 col-8 md">
        <label for="location" class="form-label">Location:</label>
        <input type="text"  name="listing[location]" class="form-control" placeholder="Enter Location"required>

         <div class="invalid-feedback">Enter a valid Location!</div>
          
        </div>
        </div>

      <br>
       <div class="mb-3">
        <label for="country" class="form-label">Country:</label>
        <input type="text"  name="listing[country]" class="form-control" placeholder="Enter Country"required>
         <div class="invalid-feedback">Enter a valid Country Name!</div>
        </div>    
     

        <button class="btn btn-dark update-btn  mt-3" type="submit">Add</button>
      
    </form>
    </div>
    </div>
    <br><br>
   
</body>
